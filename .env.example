# Gemini API Key para el Gemini Bridge — Nivel 1 del router (gratuito, alta capacidad).
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic API Key para el fallback Haiku — Nivel 2 del router (economico, confiable).
# Se activa automaticamente cuando Gemini agota su cuota (Circuit Breaker — Regla 9).
# Es la misma clave que usa Claude Code en la sesion activa.
ANTHROPIC_API_KEY=

# Ruta al directorio de documentacion interna del proyecto anfitrion.
# Usada por el servidor MCP filesystem para montar el RAG local (ver OPERATIONS.md).
# Acepta rutas relativas al raiz del repositorio o rutas absolutas.
# Ejemplo: ./docs
DOCS_PATH=./docs
